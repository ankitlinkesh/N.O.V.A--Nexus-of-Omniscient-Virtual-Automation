# Eva public-safe environment template.
# Copy to .env.local for private local use. Do not commit .env.local.

EVA_USER_NAME=
EVA_ASSISTANT_NAME=Eva
EVA_STARTUP_GREETING=
EVA_PERSONA_STYLE=chill_direct

# Public/community release flags.
EVA_PUBLIC_MODE=false
EVA_RELEASE_CHANNEL=development

# Voice and UI.
EVA_VOICE_ENABLED=true
EVA_TTS_PROVIDER=browser

# Operator/safety gates.
EVA_OPERATOR_MODE=true
EVA_OPERATOR_CONFIRM_POWER=true
EVA_OPERATOR_ALLOW_SCREEN_ON_REQUEST=true

# v2 runtime flags remain disabled by default.
EVA_V2_RUNTIME_ENABLED=false
EVA_V2_LANGGRAPH_ENABLED=false
EVA_V2_LLM_GUARD_ENABLED=false
EVA_V2_LANGFUSE_ENABLED=false
EVA_V2_PLAYWRIGHT_ENABLED=false
EVA_V2_PYAUTOGUI_ENABLED=false

# Research Memory vector search stays disabled by default.
EVA_RESEARCH_MEMORY_VECTOR_ENABLED=false

# Local fallback models. Configure only if installed locally.
EVA_LLM_MODE=auto
EVA_OLLAMA_QWEN_MODEL=
EVA_OLLAMA_LLAMA_MODEL=

# Cloud/API-backed LLM providers. Leave blank until configured privately.
GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
GROQ_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=
NVIDIA_NIM_MODEL=
CLOD_API_KEY=
CLOD_BASE_URL=
CLOD_MODEL=
TAVILY_API_KEY=

# Workspace paths. Use repo-relative defaults where possible.
EVA_WORKSPACE_ROOT=
EVA_WORKSPACE_ENABLED=true
EVA_WORKSPACE_MAX_FILE_BYTES=200000
EVA_WORKSPACE_MAX_FILES_PER_SCAN=300
EVA_WORKSPACE_EXCLUDE_DIRS=.git,.venv,venv,__pycache__,node_modules,backend/eva/data,data
EVA_WORKSPACE_EXCLUDE_FILES=.env,.env.local,*.key,*.pem,*.sqlite3,*.log
